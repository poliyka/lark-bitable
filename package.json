{
  "name": "lark-bitable",
  "version": "1.2.0",
  "type": "module",
  "description": "AI-facing Lark Bitable CLI for bug triage and evidence-backed reports.",
  "license": "MIT",
  "keywords": [
    "lark",
    "feishu",
    "bitable",
    "cli",
    "qa",
    "triage"
  ],
  "homepage": "https://github.com/poliyka/lark-bitable#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poliyka/lark-bitable.git"
  },
  "bugs": {
    "url": "https://github.com/poliyka/lark-bitable/issues"
  },
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "bin": {
    "lark-bitable": "bin/run.js"
  },
  "oclif": {
    "bin": "lark-bitable",
    "commands": "./dist/cli/commands",
    "topicSeparator": " "
  },
  "files": [
    "bin/",
    "change-log.md",
    "dist/",
    "README.md",
    "src/bootstrap/skill/SKILL.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm format:check",
    "quickstart:validate": "tsx scripts/quickstart-validate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "@oclif/core": "^4.11.1",
    "conf": "^15.1.0",
    "flatpickr": "^4.6.13",
    "open": "^11.0.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "@types/ws": "^8.18.1",
    "oclif": "^4.23.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
