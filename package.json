{
  "name": "hybrid-im-qa-lark-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-facing Lark Bitable CLI for bug triage and evidence-backed reports.",
  "bin": {
    "lark-bitable": "./bin/run.js"
  },
  "oclif": {
    "bin": "lark-bitable",
    "commands": "./dist/cli/commands",
    "topicSeparator": " "
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "src/bootstrap/skill/SKILL.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "quickstart:validate": "tsx scripts/quickstart-validate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "@oclif/core": "^4.11.1",
    "conf": "^15.1.0",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "oclif": "^4.23.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
